# Ignore every top-level directory by default. This workspace contains many
# independent Project Zomboid mod repos, and the parent repo must not absorb them.
/*/

# Track workspace instructions and Codex skills.
!/instructions/
!/instructions/**
!/skills/
!/skills/**

# Track reusable workspace helpers, but keep local binaries and generated output ignored.
!/.tools/
/.tools/*
!/.tools/decompile-pz.sh
!/.tools/pz-continue-debug.sh
